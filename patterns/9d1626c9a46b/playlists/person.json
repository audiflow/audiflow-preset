{
  "displayName": "パーソナリティ",
  "episodeFilters": {
    "require": [
      {
        "title": "（[^）]+）|\\([^)]+\\)"
      }
    ]
  },
  "episodeItem": {
    "titleExtractor": {
      "fallback": {
        "group": 1,
        "pattern": "（([^）]+)）",
        "source": "title"
      },
      "group": 1,
      "pattern": "\\(([^)]+)\\)",
      "source": "title"
    }
  },
  "episodeListing": {
    "showYearHeaders": true
  },
  "groupItem": {
    "showDateRange": false
  },
  "groupListing": {
    "userSortable": true,
    "yearBinding": "splitByYear"
  },
  "grouping": {
    "by": "titleDiscovery"
  },
  "id": "person"
}
