{
  "displayName": "Seasons",
  "episodeFilters": {
    "exclude": [
      {
        "title": "^(Best of Business Wars Daily|Encore: )"
      }
    ]
  },
  "groupItem": {
    "prependSeasonNumber": true,
    "showDateRange": true,
    "titleExtractor": {
      "group": 1,
      "pattern": "^(.*?) [-|] ",
      "source": "title"
    }
  },
  "grouping": {
    "by": "seasonNumber",
    "staticClassifiers": []
  },
  "id": "seasons"
}
