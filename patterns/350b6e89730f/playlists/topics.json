{
  "displayName": "テーマ回",
  "episodeFilters": {
    "exclude": [
      {
        "title": "番外編|雑談回|特別編"
      }
    ],
    "require": [
      {
        "title": "（(?:その\\d+|[前中後]編)）"
      }
    ]
  },
  "groupItem": {
    "showDateRange": true,
    "titleExtractor": {
      "group": 1,
      "pattern": "^#\\d+ *?(.*?)（(?:その\\d+|[前中後]編)）",
      "source": "title"
    }
  },
  "groupListing": {
    "sort": {
      "field": "newestEpisodeDate",
      "order": "ascending"
    },
    "userSortable": true,
    "yearBinding": "pinToYear"
  },
  "grouping": {
    "by": "titleDiscovery"
  },
  "id": "topics",
  "priority": 0
}
