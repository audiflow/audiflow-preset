{
  "displayName": "レギュラーシリーズ",
  "episodeFilters": {
    "exclude": [
      {
        "title": "【COTEN RADIO\\s*ショート"
      }
    ],
    "require": [
      {
        "title": "【\\d+-\\d+】"
      }
    ]
  },
  "groupItem": {
    "showDateRange": true,
    "titleExtractor": {
      "fallback": {
        "group": 1,
        "pattern": "【COTEN RADIO\\s*(.+?)\\s*(\\d+)】",
        "source": "title"
      },
      "fallbackValue": "その他",
      "group": 1,
      "pattern": "【COTEN RADIO\\s*([^】]+)編\\s*(\\d+)】",
      "source": "title"
    }
  },
  "groupListing": {
    "sort": {
      "field": "playlistNumber",
      "order": "ascending"
    },
    "userSortable": true,
    "yearBinding": "pinToYear"
  },
  "grouping": {
    "by": "seasonNumber",
    "numberingExtractor": {
      "episodeGroup": 2,
      "fallbackEpisodePattern": "(\\d+)】",
      "fallbackSeasonNumber": 0,
      "fallbackToRss": true,
      "pattern": "【(\\d+)-(\\d+)】",
      "seasonGroup": 1,
      "source": "title"
    }
  },
  "id": "regular"
}
